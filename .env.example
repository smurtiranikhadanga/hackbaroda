# ── AI Provider ─────────────────────────────────────────────────────────────
# Choose "gemini", "openai", or "groq"
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=incident_user
POSTGRES_PASSWORD=incident_pass
POSTGRES_DB=incidents
DATABASE_URL=postgresql://incident_user:incident_pass@localhost:5432/incidents

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=incidents

# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string_in_production
ENVIRONMENT=development

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
